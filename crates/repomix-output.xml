    fn bool_to_string() {
        let ptr = hulk_rt_bool_to_string(true);
        assert!(!ptr.is_null());
        unsafe {
            assert_eq!(string_from_ptr(ptr), "true");
            hulk_rt_release(ptr);
        }
        let ptr2 = hulk_rt_bool_to_string(false);
        assert!(!ptr2.is_null());
        unsafe {
            assert_eq!(string_from_ptr(ptr2), "false");
            hulk_rt_release(ptr2);
        }
