    #[test]
    fn string_concat() {
        let a = hulk_rt_number_to_string(10.0);
        let b = hulk_rt_bool_to_string(true);
        let c = hulk_rt_string_concat(a, b);
        assert!(!c.is_null());
        unsafe {
            assert_eq!(string_from_ptr(c), "10true");
            hulk_rt_release(a);
            hulk_rt_release(b);
